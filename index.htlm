<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cine Comunidad</title>
    <style>
        /* ----- RESET & BASE ----- */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            cursor: none;
        }

        body {
            background: #ffffff;
            font-family: 'Georgia', 'Times New Roman', serif;
            color: #1a1a1a;
            line-height: 1.7;
            padding: 2rem 1.5rem;
        }

        /* ----- STAR CURSOR ----- */
        #star-cursor {
            position: fixed;
            pointer-events: none;
            z-index: 9999;
            font-size: 1.8rem;
            color: #6698f8;
            opacity: 0.7;
            transform: translate(-50%, -50%);
            transition: transform 0.15s ease;
            text-shadow: 0 0 15px rgba(102, 152, 248, 0.3);
        }

        /* ----- CONTAINER ----- */
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 1rem;
        }

        /* ----- NAVIGATION ----- */
        .navbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            padding: 0.5rem 0 2rem 0;
            border-bottom: 2px solid #f0f0f0;
            margin-bottom: 3rem;
        }

        .logo img {
            max-height: 60px;
            width: auto;
            display: block;
        }

        .nav-links {
            display: flex;
            gap: 1.8rem;
            align-items: center;
            flex-wrap: wrap;
            font-size: 0.95rem;
            letter-spacing: 0.02em;
        }

        .nav-links a {
            text-decoration: none;
            color: #1a1a1a;
            font-weight: 400;
            transition: color 0.3s ease;
            position: relative;
            padding-bottom: 2px;
        }

        .nav-links a:hover {
            color: #6698f8;
        }

        .nav-links a::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            width: 0;
            height: 1px;
            background: #6698f8;
            transition: width 0.3s ease;
        }

        .nav-links a:hover::after {
            width: 100%;
        }

        .lang-btn {
            background: none;
            border: 1.5px solid #6698f8;
            color: #6698f8;
            padding: 0.3rem 1rem;
            border-radius: 30px;
            font-size: 0.8rem;
            font-weight: 500;
            transition: all 0.3s ease;
            cursor: pointer;
            font-family: 'Georgia', serif;
            letter-spacing: 0.05em;
        }

        .lang-btn:hover {
            background: #6698f8;
            color: white;
        }

        /* ----- HERO / MAIN STATEMENT ----- */
        .hero {
            padding: 2rem 0 4rem 0;
            position: relative;
        }

        .hero-text {
            max-width: 850px;
            margin: 0 auto;
            font-size: 1.15rem;
            line-height: 2;
            color: #1a1a1a;
            padding: 0 1rem;
        }

        .hero-text p {
            margin-bottom: 2rem;
        }

        .hero-text .highlight {
            color: #6698f8;
            font-weight: 600;
        }

        .hero-text .craft-divider {
            display: block;
            text-align: center;
            font-size: 2rem;
            color: #e7bdcd;
            margin: 1.5rem 0;
            letter-spacing: 0.5rem;
        }

        .hero-images {
            display: flex;
            gap: 1.5rem;
            justify-content: center;
            flex-wrap: wrap;
            margin: 3rem 0 1rem 0;
        }

        .hero-images .placeholder-img {
            width: 200px;
            height: 250px;
            background: #f5f0eb;
            border: 3px dashed #e7bdcd;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2.5rem;
            color: #ccc;
            border-radius: 4px;
            position: relative;
            overflow: hidden;
        }

        .hero-images .placeholder-img::before {
            content: '🎬';
            font-size: 3rem;
            opacity: 0.5;
        }

        .hero-images .placeholder-img:nth-child(2)::before {
            content: '🎞️';
        }

        .hero-images .placeholder-img:nth-child(3)::before {
            content: '✧';
            font-size: 4rem;
            color: #6698f8;
        }

        .hero-images .placeholder-img .film-grain {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: repeating-linear-gradient(0deg, 
                rgba(0,0,0,0.02) 0px, 
                rgba(0,0,0,0.02) 2px, 
                transparent 2px, 
                transparent 4px);
            pointer-events: none;
        }

        /* ----- SECTION TITLES ----- */
        .section-title {
            font-size: 2.2rem;
            font-weight: 400;
            letter-spacing: -0.02em;
            margin: 4rem 0 2rem 0;
            padding-bottom: 0.5rem;
            border-bottom: 3px solid #6698f8;
            display: inline-block;
            font-family: 'Georgia', serif;
        }

        .section-title .accent-dot {
            color: #e7bdcd;
            font-size: 2rem;
            margin-left: 0.3rem;
        }

        /* ----- ARCHIVO & TEXTOS GRID ----- */
        .grid-container {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 2.5rem;
            margin: 2rem 0 3rem 0;
        }

        .grid-item {
            background: #faf8f6;
            border-radius: 8px;
            overflow: hidden;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            border: 1px solid #f0ebe6;
        }

        .grid-item:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 30px -10px rgba(0,0,0,0.08);
        }

        .grid-item .grid-img {
            width: 100%;
            height: 220px;
            background: #f0ebe6;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 3rem;
            color: #ccc;
            position: relative;
            overflow: hidden;
        }

        .grid-item .grid-img .film-strip {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: repeating-linear-gradient(90deg, 
                rgba(0,0,0,0.03) 0px, 
                rgba(0,0,0,0.03) 8px, 
                transparent 8px, 
                transparent 12px);
            pointer-events: none;
        }

        .grid-item .grid-img .placeholder-icon {
            font-size: 3.5rem;
            opacity: 0.4;
            z-index: 1;
        }

        .grid-item .grid-content {
            padding: 1.5rem 1.5rem 1.8rem;
        }

        .grid-item .grid-content h3 {
            font-size: 1.2rem;
            font-weight: 600;
            margin-bottom: 0.5rem;
            color: #1a1a1a;
            font-family: 'Georgia', serif;
        }

        .grid-item .grid-content p {
            font-size: 0.95rem;
            color: #555;
            margin-bottom: 1rem;
            line-height: 1.6;
        }

        .grid-item .grid-content a {
            color: #6698f8;
            text-decoration: none;
            font-weight: 500;
            font-size: 0.9rem;
            border-bottom: 1px solid transparent;
            transition: border-color 0.3s ease;
        }

        .grid-item .grid-content a:hover {
            border-bottom-color: #6698f8;
        }

        /* ----- PRÓXIMOS EVENTOS ----- */
        .events-container {
            background: #faf8f6;
            border-radius: 12px;
            padding: 3rem 2.5rem;
            border: 1px solid #f0ebe6;
            margin: 2rem 0 3rem 0;
            text-align: center;
        }

        .events-container .no-events {
            font-size: 1.4rem;
            color: #6698f8;
            font-family: 'Georgia', serif;
            letter-spacing: 0.02em;
        }

        .events-container .no-events .emoji {
            display: block;
            font-size: 3rem;
            margin-bottom: 1rem;
        }

        .events-container .flyer-placeholder {
            width: 100%;
            max-width: 400px;
            height: 250px;
            background: #f0ebe6;
            margin: 0 auto 1.5rem auto;
            border: 3px dashed #e7bdcd;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            color: #999;
            font-family: 'Georgia', serif;
        }

        .events-container .flyer-placeholder::before {
            content: '🎫 próximamente...';
            opacity: 0.6;
        }

        /* ----- NOSOTRAS GRID ----- */
        .nosotras-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 3rem;
            margin: 2rem 0 3rem 0;
        }

        .nosotras-item {
            background: #faf8f6;
            border-radius: 12px;
            overflow: hidden;
            border: 1px solid #f0ebe6;
            transition: transform 0.3s ease;
        }

        .nosotras-item:hover {
            transform: scale(1.01);
        }

        .nosotras-item .nosotras-img {
            width: 100%;
            height: 280px;
            background: #f0ebe6;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 4rem;
            color: #ccc;
            position: relative;
            overflow: hidden;
        }

        .nosotras-item .nosotras-img .portrait-placeholder {
            font-size: 5rem;
            opacity: 0.3;
        }

        .nosotras-item .nosotras-content {
            padding: 1.8rem 1.8rem 2rem;
        }

        .nosotras-item .nosotras-content h3 {
            font-size: 1.4rem;
            font-weight: 600;
            margin-bottom: 0.3rem;
            color: #1a1a1a;
            font-family: 'Georgia', serif;
        }

        .nosotras-item .nosotras-content .role-tag {
            display: inline-block;
            background: #e7bdcd;
            color: #1a1a1a;
            padding: 0.1rem 1rem;
            border-radius: 30px;
            font-size: 0.7rem;
            letter-spacing: 0.05em;
            margin-bottom: 0.8rem;
            font-weight: 500;
        }

        .nosotras-item .nosotras-content p {
            font-size: 0.95rem;
            color: #444;
            line-height: 1.8;
        }

        /* ----- NEWSLETTER ----- */
        .newsletter {
            background: #faf8f6;
            border-radius: 12px;
            padding: 3rem 2rem;
            margin: 4rem 0 3rem 0;
            text-align: center;
            border: 1px solid #f0ebe6;
        }

        .newsletter h3 {
            font-size: 1.6rem;
            font-weight: 400;
            margin-bottom: 0.5rem;
            font-family: 'Georgia', serif;
            color: #1a1a1a;
        }

        .newsletter p {
            color: #666;
            margin-bottom: 1.5rem;
            font-size: 0.95rem;
        }

        .newsletter-form {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 0.8rem;
            max-width: 500px;
            margin: 0 auto;
        }

        .newsletter-form input {
            flex: 1;
            min-width: 200px;
            padding: 0.9rem 1.2rem;
            border: 1.5px solid #ddd;
            border-radius: 60px;
            font-size: 0.95rem;
            font-family: 'Georgia', serif;
            background: white;
            transition: border-color 0.3s ease;
        }

        .newsletter-form input:focus {
            outline: none;
            border-color: #6698f8;
        }

        .newsletter-form button {
            background: #6698f8;
            color: white;
            border: none;
            padding: 0.9rem 2.5rem;
            border-radius: 60px;
            font-size: 0.95rem;
            font-weight: 500;
            font-family: 'Georgia', serif;
            transition: background 0.3s ease, transform 0.2s ease;
            cursor: pointer;
            letter-spacing: 0.05em;
        }

        .newsletter-form button:hover {
            background: #4a7ed4;
            transform: scale(1.02);
        }

        /* ----- FOOTER ----- */
        .footer {
            padding: 3rem 0 1.5rem 0;
            border-top: 2px solid #f0f0f0;
            margin-top: 3rem;
            text-align: center;
        }

        .footer-links {
            display: flex;
            justify-content: center;
            gap: 2.5rem;
            flex-wrap: wrap;
            margin-bottom: 1.5rem;
        }

        .footer-links a {
            color: #1a1a1a;
            text-decoration: none;
            font-size: 1rem;
            transition: color 0.3s ease;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .footer-links a:hover {
            color: #6698f8;
        }

        .footer-links a .icon {
            font-size: 1.3rem;
        }

        .footer-copy {
            font-size: 0.85rem;
            color: #999;
            margin-top: 1rem;
        }

        .footer-copy .craft-heart {
            color: #e7bdcd;
        }

        /* ----- RESPONSIVE ----- */
        @media (max-width: 768px) {
            .navbar {
                flex-direction: column;
                align-items: flex-start;
                gap: 1rem;
            }

            .nav-links {
                gap: 1rem;
                font-size: 0.85rem;
                width: 100%;
                justify-content: space-between;
            }

            .hero-text {
                font-size: 1rem;
                padding: 0;
            }

            .hero-images .placeholder-img {
                width: 140px;
                height: 180px;
            }

            .section-title {
                font-size: 1.8rem;
            }

            .grid-container {
                grid-template-columns: 1fr 1fr;
                gap: 1.5rem;
            }

            .nosotras-grid {
                grid-template-columns: 1fr;
            }

            .events-container {
                padding: 2rem 1.5rem;
            }

            .newsletter-form input {
                min-width: 150px;
            }
        }

        @media (max-width: 480px) {
            .grid-container {
                grid-template-columns: 1fr;
            }

            .nav-links {
                font-size: 0.8rem;
                gap: 0.8rem;
            }

            .hero-images .placeholder-img {
                width: 100%;
                height: 180px;
            }
        }

        /* ----- CRAFTY EXTRAS ----- */
        .craft-doodle {
            display: inline-block;
            color: #e7bdcd;
            font-size: 1.2rem;
            margin: 0 0.2rem;
        }

        .accent-color-1 { color: #e7bdcd; }
        .accent-color-2 { color: #67242a; }
        .accent-color-3 { color: #5c7b81; }
        .accent-color-4 { color: #350b05; }

        .border-craft {
            border: 2px solid #e7bdcd;
            border-radius: 4px;
            padding: 0.2rem 0.8rem;
            display: inline-block;
        }

        /* subtle film grain texture for backgrounds */
        .film-grain-bg {
            position: relative;
        }

        .film-grain-bg::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.05'/%3E%3C/svg%3E");
            pointer-events: none;
            opacity: 0.3;
            z-index: 0;
        }

        /* make sure content sits above grain */
        .hero, .grid-item, .nosotras-item, .events-container, .newsletter {
            position: relative;
            z-index: 1;
        }

        /* ----- LANGUAGE TOGGLE (visual only for now) ----- */
        .lang-toggle {
            display: inline-flex;
            align-items: center;
            gap: 0.3rem;
        }

        .lang-toggle .lang-divider {
            color: #ccc;
            font-size: 0.8rem;
        }

        .lang-toggle .lang-active {
            color: #6698f8;
            font-weight: 600;
        }

        .lang-toggle .lang-inactive {
            color: #aaa;
            cursor: pointer;
            transition: color 0.3s ease;
        }

        .lang-toggle .lang-inactive:hover {
            color: #6698f8;
        }
    </style>
</head>
<body>

    <!-- STAR CURSOR -->
    <div id="star-cursor">✧</div>

    <div class="container">

        <!-- NAVIGATION -->
        <nav class="navbar">
            <div class="logo">
                <!-- REPLACE "logo-placeholder.png" WITH YOUR ACTUAL LOGO FILENAME -->
                <img src="logo-placeholder.png" alt="Cine Comunidad">
            </div>
            <div class="nav-links">
                <a href="#archivo">Archivo</a>
                <a href="#eventos">Próximos Eventos</a>
                <a href="#textos">Textos</a>
                <a href="#nosotras">Nosotras</a>
                <div class="lang-toggle">
                    <span class="lang-active">ES</span>
                    <span class="lang-divider">|</span>
                    <span class="lang-inactive">EN</span>
                </div>
            </div>
        </nav>

        <!-- HERO / MAIN STATEMENT -->
        <section class="hero">
            <div class="hero-text">
                <p>
                    <span class="highlight">CineComunidad</span> es un cineclub itinerante, independiente y emergente que apuesta por la colaboración interdisciplinaria para crear espacios de encuentro, diálogo y comunidad en torno al cine.
                </p>

                <span class="craft-divider">✧ ✧ ✧</span>

                <p>
                    <span class="highlight">El cine nos (re)une</span><br>
                    El cine no sólo se mira, ni tampoco se mira solx: el cine se comparte. Cada función es una oportunidad para (re)unirnos, (re)conocernos y conectar desde experiencias diversas.
                </p>

                <p>
                    <span class="highlight">El cine nos (con)mueve</span><br>
                    El espacio afecta nuestra experiencia de visualización. Por eso, CineComunidad es un proyecto en movimiento: habita distintos entornos para que el cine entre en diálogo con su lugar de exhibición y nos permita ver desde otras posiciones.
                </p>

                <p>
                    <span class="highlight">El cine nos (ex)tiende la mirada</span><br>
                    Una comunidad para cine poco común. Proyectamos filmes que desbordan lo habitual para ampliar nuestro horizonte cinematográfico y acercarnos a problemáticas que interpelan nuestras realidades.
                </p>
            </div>

            <!-- PLACEHOLDER IMAGES -->
            <div class="hero-images">
                <div class="placeholder-img">
                    <div class="film-grain"></div>
                </div>
                <div class="placeholder-img">
                    <div class="film-grain"></div>
                </div>
                <div class="placeholder-img">
                    <div class="film-grain"></div>
                </div>
            </div>
        </section>

        <!-- ARCHIVO -->
        <section id="archivo">
            <h2 class="section-title">Archivo <span class="accent-dot">·</span></h2>
            <div class="grid-container">
                <!-- Grid Item 1 -->
                <div class="grid-item">
                    <div class="grid-img">
                        <span class="placeholder-icon">🎬</span>
                        <div class="film-strip"></div>
                    </div>
                    <div class="grid-content">
                        <h3>Título del proyecto</h3>
                        <p>Breve descripción del proyecto. Aquí puedes escribir sobre el film, la actividad o el taller realizado.</p>
                        <a href="#">Ver más →</a>
                    </div>
                </div>
                <!-- Grid Item 2 -->
                <div class="grid-item">
                    <div class="grid-img">
                        <span class="placeholder-icon">🎞️</span>
                        <div class="film-strip"></div>
                    </div>
                    <div class="grid-content">
                        <h3>Título del proyecto</h3>
                        <p>Breve descripción del proyecto. Aquí puedes escribir sobre el film, la actividad o el taller realizado.</p>
                        <a href="#">Ver más →</a>
                    </div>
                </div>
                <!-- Grid Item 3 -->
                <div class="grid-item">
                    <div class="grid-img">
                        <span class="placeholder-icon">📽️</span>
                        <div class="film-strip"></div>
                    </div>
                    <div class="grid-content">
                        <h3>Título del proyecto</h3>
                        <p>Breve descripción del proyecto. Aquí puedes escribir sobre el film, la actividad o el taller realizado.</p>
                        <a href="#">Ver más →</a>
                    </div>
                </div>
                <!-- Grid Item 4 -->
                <div class="grid-item">
                    <div class="grid-img">
                        <span class="placeholder-icon">✧</span>
                        <div class="film-strip"></div>
                    </div>
                    <div class="grid-content">
                        <h3>Título del proyecto</h3>
                        <p>Breve descripción del proyecto. Aquí puedes escribir sobre el film, la actividad o el taller realizado.</p>
                        <a href="#">Ver más →</a>
                    </div>
                </div>
            </div>
        </section>

        <!-- PRÓXIMOS EVENTOS -->
        <section id="eventos">
            <h2 class="section-title">Próximos Eventos <span class="accent-dot">·</span></h2>
            <div class="events-container">
                <div class="no-events">
                    <span class="emoji">🎬</span>
                    Por el momento no tenemos próximos eventos. Esperamos anunciarlos pronto! :)
                </div>
                <!-- 
                    CUANDO TENGAS UN EVENTO, REEMPLAZA EL BLOQUE DE ARRIBA CON ESTO:
                    <div class="flyer-placeholder"></div>
                    <p style="font-size: 1.1rem; color: #1a1a1a; max-width: 600px; margin: 0 auto;">
                        <strong>Nombre del evento</strong><br>
                        Descripción del evento. Fecha, hora, lugar y toda la información que quieras compartir.
                    </p>
                -->
            </div>
        </section>

        <!-- TEXTOS -->
        <section id="textos">
            <h2 class="section-title">Textos <span class="accent-dot">·</span></h2>
            <div class="grid-container">
                <!-- Grid Item 1 -->
                <div class="grid-item">
                    <div class="grid-img">
                        <span class="placeholder-icon">📄</span>
                        <div class="film-strip"></div>
                    </div>
                    <div class="grid-content">
                        <h3>Título del texto</h3>
                        <p>Breve descripción o extracto del texto. Puede ser un ensayo, una crítica o una reflexión.</p>
                        <a href="#">Leer más →</a>
                    </div>
                </div>
                <!-- Grid Item 2 -->
                <div class="grid-item">
                    <div class="grid-img">
                        <span class="placeholder-icon">✍️</span>
                        <div class="film-strip"></div>
                    </div>
                    <div class="grid-content">
                        <h3>Título del texto</h3>
                        <p>Breve descripción o extracto del texto. Puede ser un ensayo, una crítica o una reflexión.</p>
                        <a href="#">Leer más →</a>
                    </div>
                </div>
                <!-- Grid Item 3 -->
                <div class="grid-item">
                    <div class="grid-img">
                        <span class="placeholder-icon">📖</span>
                        <div class="film-strip"></div>
                    </div>
                    <div class="grid-content">
                        <h3>Título del texto</h3>
                        <p>Breve descripción o extracto del texto. Puede ser un ensayo, una crítica o una reflexión.</p>
                        <a href="#">Leer más →</a>
                    </div>
                </div>
            </div>
        </section>

        <!-- NOSOTRAS -->
        <section id="nosotras">
            <h2 class="section-title">Nosotras <span class="accent-dot">·</span></h2>
